{
	"name": "@hvault/server",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"db:push": "drizzle-kit push",
		"db:local": "wrangler d1 migrations apply hvault --local",
		"db:migrate": "drizzle-kit migrate",
		"auth:generate": "pnpm dlx @better-auth/cli generate --config ./src/lib/auth.ts --output ./src/repo/schema/auth.schema.ts",
		"better-auth-gen-schema": "pnpm dlx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ./src/repo/schema/auth.schema.ts",
		"db:generate": "drizzle-kit generate",
		"lint": "biome check",
		"format": "biome format",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@aws-sdk/client-kms": "^3.994.0",
		"@hashgraph/sdk": "^2.80.0",
		"@hono/standard-validator": "^0.2.2",
		"@scalar/hono-api-reference": "^0.9.44",
		"asn1.js": "^5.4.1",
		"better-auth": "^1.4.18",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"effect": "^3.19.18",
		"elliptic": "^6.6.1",
		"hono": "^4.12.0",
		"hono-openapi": "^1.2.0",
		"hono-pino": "^0.10.3",
		"keccak256": "^1.0.6",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.3",
		"@cloudflare/workers-types": "^4.20260227.0",
		"@types/bun": "^1.3.9",
		"@types/node": "^25.3.0",
		"drizzle-kit": "^0.31.9",
		"wrangler": "^4.67.0"
	}
}
