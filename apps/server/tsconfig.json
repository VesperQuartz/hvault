{
	"extends": "@hvault/typescript-config/base.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"worker-configuration.d.ts"
		],
		"lib": [
			"ESNext"
		],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"baseUrl": ".",
		"paths": {
			"#/*": [
				"./*"
			]
		}
	}
}
